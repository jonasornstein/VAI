{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/index" },
    { "source": "/mockup/(.*)", "destination": "/api/index" },
    { "source": "/", "destination": "/api/index" }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{tests/**,__pycache__/**,**/*.pyc,pending/**,mcps/**,betslips/**,.grok/**}"
    }
  }
}